# ==============================================================================
# 📦 SELLER APP - VARIABLES DE ENTORNO (EJEMPLO)
# ==============================================================================
# Instrucciones para los profesores/desarrolladores:
# 1. Copiar este archivo y renombrarlo a .env
# 2. Reemplazar los valores vacíos o de ejemplo por las credenciales reales
# ==============================================================================

# ------------------------------------------------------------------------------
# BASE DE DATOS (Prisma / Neon)
# ------------------------------------------------------------------------------
# URL de conexión a la base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:contraseña@servidor.neon.tech/neondb?sslmode=require"

# ------------------------------------------------------------------------------
# AUTENTICACIÓN (Clerk)
# ------------------------------------------------------------------------------
# Claves de la API (Usar pk_test_ y sk_test_ para desarrollo local)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_tu_clave_publica_aca"
CLERK_SECRET_KEY="sk_test_tu_clave_secreta_aca"

# Rutas por defecto de Clerk para Next.js
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ------------------------------------------------------------------------------
# INTELIGENCIA ARTIFICIAL (Google Gemini)
# ------------------------------------------------------------------------------
# API Key generada desde Google AI Studio (No exponer del lado del cliente)
GEMINI_API_KEY="tu_clave_api_de_gemini_aca"

# ------------------------------------------------------------------------------
# INTEGRACIÓN ECOSISTEMA (APIs de otras aplicaciones)
# ------------------------------------------------------------------------------
# URLs base para la comunicación entre los distintos módulos.
# Para desarrollo local usar http://localhost:PORT
# Para producción usar https://tu-proyecto.vercel.app

NEXT_PUBLIC_BUYER_URL="http://localhost:3001"
NEXT_PUBLIC_PAYMENTS_URL="http://localhost:3002"
NEXT_PUBLIC_SHIPPING_URL="http://localhost:3003"